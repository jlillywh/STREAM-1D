# Shell scripts must use LF so WSL/bash does not break on CRLF (set: pipefail errors).
*.sh text eol=lf
postBuild text eol=lf

# Binder
runtime.txt text eol=lf
requirements.txt text eol=lf
*.md text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
