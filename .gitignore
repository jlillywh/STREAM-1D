# ====================================================================
# STREAM-1D Core Engine Ignore Rules
# ====================================================================

# Ignore the lightweight local development server
server.mjs

# Ignore the vanilla HTML/JS benchmark dashboard files
index.html
worker.js

# Ignore performance screenshots or test recordings generated by subagents
*.png
*.mp4
*.mov
benchmark_results_*.png

# Coverage reports (generated in CI)
lcov.info
coverage/

# Standard Rust / Cargo build artifacts
/target/
**/*.rs.bk

# WebAssembly package output (if you plan to publish npm packages separately)
# Note: If your JS worker explicitly imports from /pkg inside this repo, 
# you can track it, but usually, target files are ignored in the engine PR.
/pkg/
/pkg-node/

# Python-related build artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/

# Accidental root scratch (coverage logs, Windows NUL device, agent captures)
/nul
/patch_diff.txt
/cargo_*_out.txt
/cargo_test_*.txt
/*_test_out.txt
/unc_*.txt
/uncovered_snippets.txt
/_cov_patch.py
/parse_lcov_tmp.py
/parse_patch_uncovered.py
/dump_uncovered_snippets.py

# Local workspace scratch (not part of the engine)
/local/

# Oracle / agent scratch (do not commit)
verification/oracle/logs/
verification/oracle/projects/generated/
verification/oracle/scenarios/generated/
verification/oracle/**/*.log
.commit_msg*.txt
.pr_body*.txt
.pr_body*.md
pr_body.md
.venv-ci-test/
phase0_*.log
cargo_unsteady_tail.txt
oracle_files.txt
tmp_*.py
_agent_*.sh
verification/oracle/_*.log
# Agent / local diagnostic scratch (repo root)
/test_out*.txt
/test_out_*.log
/verify_out*.txt
/blob_*.txt
/err_files.txt
/git_status.txt
/idx_*.txt
/outer_loop_blobs.txt
/restore_log.txt
/shell_out.txt
/find_unsteady_blob.sh
/_run_verify_out*.sh
verification/oracle/omega_sweep_results.tsv
verification/oracle/omega_sweep_summary.json
verification/oracle/scripts/_conspan_diag_tmp.py
verification/oracle/_patch_ras_ref.py

# HEC-RAS HDF binaries — extract JSON references instead (see projects/beaver/README.md)
verification/oracle/projects/**/*.hdf

# Generated / local scratch
diff_stat_out.txt
examples/wasm/wasm_result.js
verification/oracle/projects/beaver/restart_report_beaver.json
